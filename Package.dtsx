                  name="SqlCommand"
                  dataType="System.String"
                  description="The SQL command to be executed."
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    c.*,
    s.SalesforceID
FROM dbo.Customer c
LEFT JOIN dbo.SalesforceIDMap s
    ON c.CustomerId COLLATE DATABASE_DEFAULT 
       = s.CermID COLLATE DATABASE_DEFAULT</property>
